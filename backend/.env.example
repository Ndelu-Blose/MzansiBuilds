# Copy this file to `.env` in the same folder (`backend/.env`). Never commit real `.env` files.
# Values below are placeholders — use your Supabase project dashboard and generated secrets.

# --- Database (Supabase Postgres; use the connection string from Project Settings → Database) ---
# Direct connection (port 5432). For pooler (6543), copy the full string from the dashboard instead.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://your-project-ref.supabase.co
# JWT secret from Project Settings → API → JWT Secret (for verifying Supabase-issued tokens)
SUPABASE_JWT_SECRET=

# Frontend local env compatibility
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key
REACT_APP_BACKEND_URL=http://localhost:8001

# --- Legacy app JWT (non-Supabase sessions / cookies) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Email (Resend: https://resend.com) ---
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# --- Optional: links in emails (production site URL) ---
APP_PUBLIC_URL=

# --- Optional: Google OAuth session bridge (only if you use a custom OAuth flow URL) ---
OAUTH_SESSION_DATA_URL=

# --- GitHub OAuth (for repo-backed projects) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/integrations/github/callback
# Optional alias supported by backend (same value as GITHUB_REDIRECT_URI)
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/api/integrations/github/callback
GITHUB_OAUTH_STATE_SECRET=change-me
GITHUB_TOKEN_SECRET=change-me
FRONTEND_URL=http://localhost:3000

# --- Seeded admin user on API startup (optional) ---
# ADMIN_PASSWORD must be set to create/update the admin user; there is no default password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# Local/QA only: set to true to write plaintext credentials to ADMIN_CREDENTIALS_DIR/test_credentials.md
# WRITE_ADMIN_CREDENTIALS_FILE=false
