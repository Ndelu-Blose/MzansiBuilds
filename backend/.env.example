# Copy this file to `.env` in the same folder (`backend/.env`). Never commit real `.env` files.
# Values below are placeholders — use your Supabase project dashboard and generated secrets.

# --- Database (Supabase Postgres; use the connection string from Project Settings → Database) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://your-project-ref.supabase.co
# JWT secret from Project Settings → API → JWT Secret (for verifying Supabase-issued tokens)
SUPABASE_JWT_SECRET=

# --- Legacy app JWT (non-Supabase sessions / cookies) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Email (Resend: https://resend.com) ---
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# --- Optional: links in emails (production site URL) ---
APP_PUBLIC_URL=

# --- Optional: Google OAuth session bridge (only if you use a custom OAuth flow URL) ---
OAUTH_SESSION_DATA_URL=

# --- Seeded admin user on API startup (change defaults in production) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
