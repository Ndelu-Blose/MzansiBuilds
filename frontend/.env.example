# Copy to `frontend/.env.local` for local development (do not commit real secrets).

# Supabase — Project Settings → API (Project URL + anon public key)
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# GitHub OAuth: paste into GitHub → OAuth App → Authorization callback URL.
# Usually https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback (Supabase → Auth → Providers → GitHub).
# Optional: omit if it matches REACT_APP_SUPABASE_URL + /auth/v1/callback
# REACT_APP_GITHUB_OAUTH_CALLBACK_URL=https://your-project-ref.supabase.co/auth/v1/callback

# Google Cloud → OAuth 2.0 Client → Authorized redirect URIs (same Supabase callback as GitHub).
# Optional: omit if it matches REACT_APP_SUPABASE_URL + /auth/v1/callback
# REACT_APP_GOOGLE_OAUTH_CALLBACK_URL=https://your-project-ref.supabase.co/auth/v1/callback

# FastAPI backend base URL (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional: when the dev server runs behind HTTPS or a reverse proxy, CRA may need this for HMR WebSockets.
# Example: WDS_SOCKET_PORT=443
# WDS_SOCKET_PORT=

# Google/GitHub login: enable providers in Supabase and set OAuth clients in Google Cloud + GitHub.
# Redirect URLs must include your dev/prod origin and /auth/callback — see README.md → "OAuth: Google and GitHub".
